# WhatIsUp — Central platform environment variables
# Copy to .env and fill in the values before running docker compose
#
# docker compose --env-file .env up -d

# PostgreSQL
POSTGRES_DB=whatisup
POSTGRES_USER=whatisup
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# API
SECRET_KEY=change-me-at-least-32-random-chars

# CORS: comma-separated or JSON array of allowed frontend origins
CORS_ALLOWED_ORIGINS=["https://app.example.com"]

# Email (optional — leave empty to disable email alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Fernet key for encrypting webhook/telegram secrets (generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=
