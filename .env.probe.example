# WhatIsUp — Probe agent environment variables
# Copy to .env.probe and fill in the values
#
# docker compose -f docker-compose.probe.yml --env-file .env.probe up -d

# URL of the central WhatIsUp server (no trailing slash)
CENTRAL_API_URL=https://monitoring.example.com

# API key returned by POST /api/v1/probes/register (shown only once)
PROBE_API_KEY=wiu_REPLACE_WITH_YOUR_KEY

# Probe identity — must be unique across all probes
PROBE_NAME=probe-paris-1
PROBE_LOCATION=Paris, France

# Optional tuning
HEARTBEAT_INTERVAL=30
MAX_CONCURRENT_CHECKS=10
LOG_LEVEL=INFO
