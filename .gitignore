*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Environment / secrets (NEVER commit real env files) ───────────────────────
.env
.env.*
!.env.example
!.env.probe.example

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
.cache/

