.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── SSL certificates (never commit private keys) ──────────────────────────────
nginx/ssl/
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Local test artefacts ──────────────────────────────────────────────────────
probe-*/

# ── Capacitor / Android (mobile build artefacts) ──────────────────────────────
frontend/android/.gradle/
frontend/android/build/
frontend/android/app/build/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/captures/
*.apk
*.aab
*.keystore
!debug.keystore

# ── Mobile signing secrets (NEVER commit) ─────────────────────────────────────
mobile/.secrets/

# ── Firebase / FCM client config (project_id leak; keep out of git) ──────────
frontend/android/app/google-services.json

# Local Claude Code artifacts
.claude/

# ── Local planning docs (working notes, not shipped) ──────────────────────────
plan_*.md
