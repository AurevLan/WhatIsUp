# WhatIsUp Probe — Environment Variables
# Copy to .env and fill in your values

# Central server URL
CENTRAL_API_URL=https://your-whatisup-server.example.com

# API key provided when registering the probe (shown once)
PROBE_API_KEY=wiu_your-api-key-here

# Probe identity
PROBE_NAME=my-probe-paris
PROBE_LOCATION=Paris, France

# How often to sync monitor list from central (seconds)
HEARTBEAT_INTERVAL=30

# Max parallel checks
MAX_CONCURRENT_CHECKS=10

# Logging
LOG_LEVEL=INFO
