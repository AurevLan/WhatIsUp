# WhatIsUp Server — Environment Variables
# Copy to .env and fill in your values

# Application
APP_NAME=WhatIsUp
ENVIRONMENT=development
DEBUG=true

# CRITICAL: Change in production!
SECRET_KEY=your-very-secret-key-change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://whatisup:whatisup@localhost:5432/whatisup

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP (for email alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@whatisup.example.com
SMTP_TLS=true
